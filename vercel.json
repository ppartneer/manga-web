{
  "rewrites": [
    {
      "source": "/mangadex-images/:path*",
      "destination": "https://uploads.mangadex.org/:path*"
    },
    {
      "source": "/mangadex-api/:path*",
      "destination": "https://api.mangadex.org/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
